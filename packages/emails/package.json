{
  "name": "@gw2me/emails",
  "version": "0.1.0",
  "private": true,
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "dev": "email dev",
    "build": "pnpm run clean && if test $CI; then pnpm run build:ci; else pnpm run build:local; fi",
    "build:local": "tsc --declaration --declarationMap",
    "build:ci": "tsc --declaration",
    "clean": "rm -rf dist/",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@gw2treasures/eslint-config": "0.2.1",
    "@gw2treasures/tsconfig": "0.0.1",
    "@react-email/ui": "6.0.0",
    "@types/react": "19.2.14",
    "eslint": "9.39.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  },
  "dependencies": {
    "react-email": "6.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}

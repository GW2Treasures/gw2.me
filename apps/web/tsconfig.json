{
  "extends": "@gw2treasures/tsconfig/nextjs",
  "compilerOptions": {
    // TODO: remove verbatimModuleSyntax override
    "verbatimModuleSyntax": false,
    "allowArbitraryExtensions": true,

    "paths": {
      "@/app/*": ["./app/*"],
      "@/components/*": ["./components/*"],
      "@/lib/*": ["./lib/*"]
    },

    "libReplacement": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/.well-known/**/*.ts",
    ".next/types/**/*.ts",
    "vitest.config.mts",
  ],
}

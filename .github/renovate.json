{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":pinAllExceptPeerDependencies"
  ],
  "ignorePresets": [
    "security:minimumReleaseAgeNpm"
  ],
  "addLabels": [
    "dependencies"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "kubernetes/.+\\.yaml$"
    ]
  },
  "ignorePaths": [
    "**/node_modules/**",
    "docker-compose.database-migration.yml"
  ],
  "postUpdateOptions": [
    "pnpmDedupe"
  ],
  "packageRules": [
    {
      "matchSourceUrls": "https://github.com/GW2Treasures/gw2treasures.com",
      "groupName": "gw2treasures packages"
    },
    {
      "matchDatasources": [
        "npm"
      ],
      "matchPackageNames": [
        "@simplewebauthn/**"
      ],
      "groupName": "SimpleWebAuthn"
    },
    {
      "matchDatasources": [
        "npm"
      ],
      "matchPackageNames": [
        "@react-email/**",
        "react-email"
      ],
      "groupName": "react-email"
    },
    {
      "description": "Don't pin dependencies in published packages",
      "matchFileNames": [
        "packages/client/package.json"
      ],
      "matchDepTypes": [
        "dependencies"
      ],
      "rangeStrategy": "replace"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update version variables in Dockerfiles",
      "managerFilePatterns": [
        "/(^|/|\\.)Dockerfile$/",
        "/(^|/)Dockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s(?:ENV|ARG) .+?_version=(?<currentValue>.+?)\\s"
      ]
    },
    {
      "customType": "regex",
      "description": "Update version variables in Github Actions workflows",
      "managerFilePatterns": [
        "/^\\.github/(workflows|actions)/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s+.+?_VERSION: (?<currentValue>.+?)\\s"
      ]
    }
  ]
}
